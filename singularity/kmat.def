Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential ca-certificates cmake git pkg-config wget zlib1g-dev
    rm -rf /var/lib/apt/lists/*

    # KMC for production kmat count (disk-backed, multithreaded).
    apt-get update
    if apt-get install -y --no-install-recommends kmc; then
        echo "installed kmc from apt"
    else
        echo "apt kmc unavailable; downloading KMC3 release binaries"
        mkdir -p /opt/kmc /usr/local/bin
        cd /tmp
        wget -q https://github.com/refresh-bio/KMC/releases/download/v3.2.4/KMC3.2.4.linux.x64.tar.gz
        tar -xzf KMC3.2.4.linux.x64.tar.gz
        # Layout varies by release; find binaries.
        find . -type f -name kmc -perm -111 -exec cp {} /usr/local/bin/kmc \;
        find . -type f -name kmc_tools -perm -111 -exec cp {} /usr/local/bin/kmc_tools \;
        chmod +x /usr/local/bin/kmc /usr/local/bin/kmc_tools
        rm -rf /tmp/*KMC* /tmp/kmc* 2>/dev/null || true
        rm -f /tmp/*.tar.gz 2>/dev/null || true
    fi
    rm -rf /var/lib/apt/lists/*
    command -v kmc
    command -v kmc_tools

    git clone --depth 1 https://github.com/martinjvickers/kmat.git /opt/kmat-src

    if [ -f /opt/kmat-src/CMakeLists.txt ]; then
        SRC=/opt/kmat-src
    else
        SRC=/opt/kmat-src/kmat
    fi

    cmake -S $SRC -B /tmp/kmat-build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DKMAT_BUILD_TESTS=OFF \
        -DKMAT_BUILD_BENCHES=OFF
    cmake --build /tmp/kmat-build -j$(nproc)
    cmake --install /tmp/kmat-build
    rm -rf /tmp/kmat-build /opt/kmat-src

%environment
    export LC_ALL=C
    export PATH="/usr/local/bin:${PATH}"

%runscript
    exec kmat "$@"
