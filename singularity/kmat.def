Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential ca-certificates cmake git pkg-config wget zlib1g-dev
    rm -rf /var/lib/apt/lists/*

    # Upstream KMC only — do NOT apt-install kmc (distro builds often break on .fq.gz).
    echo "installing upstream KMC 3.2.4"
    mkdir -p /usr/local/bin
    cd /tmp
    wget -O KMC3.2.4.linux.x64.tar.gz \
      https://github.com/refresh-bio/KMC/releases/download/v3.2.4/KMC3.2.4.linux.x64.tar.gz
    tar -xzf KMC3.2.4.linux.x64.tar.gz
    KMC_BIN=$(find /tmp -type f -name kmc ! -name '*.*' | head -n 1)
    TOOLS_BIN=$(find /tmp -type f -name kmc_tools ! -name '*.*' | head -n 1)
    if [ -z "$KMC_BIN" ] || [ -z "$TOOLS_BIN" ]; then
        echo "ERROR: kmc/kmc_tools not found in release tarball" >&2
        find /tmp -maxdepth 3 -type f | head -50 >&2
        exit 1
    fi
    cp -f "$KMC_BIN" /usr/local/bin/kmc
    cp -f "$TOOLS_BIN" /usr/local/bin/kmc_tools
    chmod +x /usr/local/bin/kmc /usr/local/bin/kmc_tools
    rm -rf /tmp/KMC3.2.4.linux.x64.tar.gz
    find /tmp -maxdepth 2 -type d -name 'kmc*' -exec rm -rf {} + 2>/dev/null || true
    find /tmp -maxdepth 2 -type d -name 'bin' -exec rm -rf {} + 2>/dev/null || true
    /usr/local/bin/kmc 2>/dev/null || true
    ls -la /usr/local/bin/kmc /usr/local/bin/kmc_tools
    # Ensure apt kmc is not present / not preferred
    if [ -e /usr/bin/kmc ] && [ ! -L /usr/bin/kmc ]; then
        echo "NOTE: /usr/bin/kmc exists; PATH prefers /usr/local/bin"
    fi

    git clone --depth 1 https://github.com/martinjvickers/kmat.git /opt/kmat-src

    if [ -f /opt/kmat-src/CMakeLists.txt ]; then
        SRC=/opt/kmat-src
    else
        SRC=/opt/kmat-src/kmat
    fi

    cmake -S $SRC -B /tmp/kmat-build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DKMAT_BUILD_TESTS=OFF \
        -DKMAT_BUILD_BENCHES=OFF
    cmake --build /tmp/kmat-build -j$(nproc)
    cmake --install /tmp/kmat-build
    rm -rf /tmp/kmat-build /opt/kmat-src

%environment
    export LC_ALL=C
    export PATH="/usr/local/bin:${PATH}"

%runscript
    exec kmat "$@"
