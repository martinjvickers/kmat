Bootstrap: docker
From: ubuntu:22.04

%labels
    Author kmat
    Version 0.4.0
    Description k-mer presence/absence GWAS toolkit (kmat)

%help
    Build from the repository root (the directory that contains kmat/):

      singularity build --fakeroot kmat.sif singularity/kmat.def

    Or on an HPC build node with sudo / singularity pro:

      singularity build kmat.sif singularity/kmat.def

    Run:

      singularity exec --bind /path/to/data:/data kmat.sif kmat --help

%setup
    set -euo pipefail
    # Paths in %setup are relative to the directory where `singularity build` is run.
    if [ ! -f "${PWD}/kmat/CMakeLists.txt" ]; then
        echo "ERROR: run singularity build from the repo root (directory containing kmat/)" >&2
        echo "  cwd=${PWD}" >&2
        exit 1
    fi
    mkdir -p "${SINGULARITY_ROOTFS}/opt/kmat-src"
    rsync -a \
        --exclude 'build/' \
        --exclude '.git/' \
        --exclude '*.o' \
        --exclude '.DS_Store' \
        "${PWD}/kmat/" "${SINGULARITY_ROOTFS}/opt/kmat-src/"

%post
    set -euo pipefail
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        git \
        pkg-config \
        rsync \
        zlib1g-dev
    rm -rf /var/lib/apt/lists/*

    cmake -S /opt/kmat-src -B /tmp/kmat-build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/kmat \
        -DKMAT_BUILD_TESTS=OFF \
        -DKMAT_BUILD_BENCHES=OFF
    cmake --build /tmp/kmat-build -j"$(nproc)"
    cmake --install /tmp/kmat-build
    rm -rf /tmp/kmat-build /opt/kmat-src

%environment
    export PATH="/opt/kmat/bin:${PATH}"
    export LC_ALL=C.UTF-8

%runscript
    exec kmat "$@"

%test
    set -e
    command -v kmat
    kmat --help >/dev/null
