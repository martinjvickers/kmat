Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential ca-certificates cmake git pkg-config zlib1g-dev
    rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/martinjvickers/kmat.git /opt/kmat-src

    # Repo may be either flat (CMakeLists at root) or have a kmat/ subdir
    if [ -f /opt/kmat-src/CMakeLists.txt ]; then
        SRC=/opt/kmat-src
    else
        SRC=/opt/kmat-src/kmat
    fi

    cmake -S $SRC -B /tmp/kmat-build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DKMAT_BUILD_TESTS=OFF \
        -DKMAT_BUILD_BENCHES=OFF
    cmake --build /tmp/kmat-build -j$(nproc)
    cmake --install /tmp/kmat-build
    rm -rf /tmp/kmat-build /opt/kmat-src

%environment
    export LC_ALL=C

%runscript
    exec kmat "$@"
