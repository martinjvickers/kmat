Bootstrap: docker
From: ubuntu:22.04

# Works from anywhere — no %files / local patch tree required:
#   sudo singularity build ~/bin/kmat.img kmat.def
# Patches are taken from the kmat git clone below.
# Build scratch lives under /opt/tmp (never host /tmp).

%post
    set -e
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential ca-certificates cmake git pkg-config python3 wget zlib1g-dev
    rm -rf /var/lib/apt/lists/*

    mkdir -p /opt/tmp
    WORK=/opt/tmp

    echo "cloning kmat (provides KMC patches + sources)"
    rm -rf /opt/kmat-src
    git clone --depth 1 https://github.com/martinjvickers/kmat.git /opt/kmat-src

    if [ -f /opt/kmat-src/CMakeLists.txt ]; then
        SRC=/opt/kmat-src
        PATCH_DIR=/opt/kmat-src/singularity/patches
    else
        SRC=/opt/kmat-src/kmat
        PATCH_DIR=/opt/kmat-src/singularity/patches
    fi

    if [ ! -f "$PATCH_DIR/binary_reader.h" ] || [ ! -f "$PATCH_DIR/apply-kmc-system-zlib.sh" ]; then
        echo "ERROR: KMC patches missing at $PATCH_DIR" >&2
        ls -la /opt/kmat-src /opt/kmat-src/singularity 2>/dev/null || true
        exit 1
    fi

    # Build KMC from source with system zlib + gzFile reader patch.
    # Stock release binaries fail on many real .fq.gz with:
    #   "Some error while reading gzip file"
    echo "building patched KMC 3.2.4 (system zlib + gzread)"
    rm -rf "$WORK/KMC"
    git clone --depth 1 --branch v3.2.4 https://github.com/refresh-bio/KMC.git "$WORK/KMC"
    cd "$WORK/KMC"
    cp -f "$PATCH_DIR/binary_reader.h" kmc_core/binary_reader.h
    python3 "$PATCH_DIR/apply-kmc-system-zlib.sh"

    make -j"$(nproc)" kmc kmc_tools
    install -m 0755 bin/kmc bin/kmc_tools /usr/local/bin/
    /usr/local/bin/kmc 2>/dev/null || true
    ldd /usr/local/bin/kmc || true

    cmake -S "$SRC" -B "$WORK/kmat-build" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DKMAT_BUILD_TESTS=OFF \
        -DKMAT_BUILD_BENCHES=OFF
    cmake --build "$WORK/kmat-build" -j"$(nproc)"
    cmake --install "$WORK/kmat-build"

    rm -rf /opt/kmat-src /opt/tmp

%environment
    export LC_ALL=C
    export PATH="/usr/local/bin:${PATH}"

%runscript
    exec kmat "$@"
